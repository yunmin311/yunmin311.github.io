---
import { getCollection, render } from 'astro:content';
import { getRelativeLocaleUrl } from 'astro:i18n';
import Base from '../../../layouts/Base.astro';
import VideoEmbed from '../../../components/VideoEmbed.astro';
import { getWorks, hasTranslation, slugOf } from '../../../lib/content';
import { t, type Lang } from '../../../i18n/ui';
import { formatYear } from '../../../lib/format';

export async function getStaticPaths() {
  const entries = await getCollection('works', ({ data }) => !data.draft);
  return entries.map((entry) => {
    const [lang, ...rest] = entry.id.split('/');
    return { params: { lang, slug: rest.join('/') }, props: { entry } };
  });
}

const { entry } = Astro.props;
const lang = Astro.params.lang as Lang;
const otherLang: Lang = lang === 'zh' ? 'en' : 'zh';
const slug = slugOf(entry.id);
const { Content } = await render(entry);

const list = await getWorks(lang);
const idx = list.findIndex((w) => w.id === entry.id);
const prev = idx > 0 ? list[idx - 1] : undefined;
const next = idx < list.length - 1 ? list[idx + 1] : undefined;

const altPath = (await hasTranslation('works', otherLang, slug))
  ? getRelativeLocaleUrl(otherLang, `works/${slug}`)
  : null;

const meta = [
  { label: formatYear(entry.data.date), value: '' },
  entry.data.client && { label: t(lang, 'work.client'), value: entry.data.client },
  entry.data.role && { label: t(lang, 'work.role'), value: entry.data.role },
].filter(Boolean) as { label: string; value: string }[];
---

<Base
  title={entry.data.title}
  description={entry.data.summary}
  altPath={altPath}
  ogImage={entry.data.cover.src}
>
  <article class="work">
    <header class="work-head">
      <h1>{entry.data.title}</h1>
      <p class="summary">{entry.data.summary}</p>
      <dl class="meta">
        {meta.map((m) => (
          <div class="meta-item">
            <dt>{m.label}</dt>
            {m.value && <dd>{m.value}</dd>}
          </div>
        ))}
        {entry.data.link && (
          <div class="meta-item">
            <dd>
              <a href={entry.data.link} target="_blank" rel="noopener">
                {t(lang, 'work.link')} ↗
              </a>
            </dd>
          </div>
        )}
      </dl>
    </header>

    {entry.data.video && <VideoEmbed url={entry.data.video} title={entry.data.title} />}

    <div class="work-body">
      <Content />
    </div>

    <nav class="work-pager">
      <span>{prev && <a href={getRelativeLocaleUrl(lang, `works/${slugOf(prev.id)}`)}>← {t(lang, 'work.prev')}:{prev.data.title}</a>}</span>
      <a href={getRelativeLocaleUrl(lang, 'works')}>{t(lang, 'work.backToList')}</a>
      <span>{next && <a href={getRelativeLocaleUrl(lang, `works/${slugOf(next.id)}`)}>{t(lang, 'work.next')}:{next.data.title} →</a>}</span>
    </nav>
  </article>
</Base>

<style>
  .work-head h1 {
    margin: 0 0 var(--space-2);
    font-size: var(--text-xl);
    font-weight: 600;
  }
  .summary {
    margin: 0 0 var(--space-3);
    color: var(--color-muted);
    max-width: var(--width-prose);
  }
  .meta {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2) var(--space-5);
    margin: 0 0 var(--space-5);
    font-size: var(--text-sm);
  }
  .meta-item {
    display: flex;
    gap: var(--space-2);
  }
  .meta dt {
    color: var(--color-muted);
  }
  .meta dd {
    margin: 0;
  }
  /* 正文:图片单列大图铺开,文字限阅读宽度(规格·作品详情) */
  .work-body {
    margin-block: var(--space-5);
  }
  .work-body :global(p) {
    max-width: var(--width-prose);
  }
  /* markdown 会把独占一行的图片包进段落;这类段落解除阅读宽度,让图铺开 */
  .work-body :global(p:has(> img)) {
    max-width: none;
  }
  .work-body :global(img) {
    width: 100%;
    height: auto; /* 压掉 img 的 height 属性,否则照片会被拉变形(同封面的教训) */
    margin-block: var(--space-4);
  }
  .work-pager {
    display: flex;
    flex-wrap: wrap;
    justify-content: space-between;
    gap: var(--space-3);
    margin-top: var(--space-6);
    padding-top: var(--space-4);
    border-top: 1px solid var(--color-line);
    font-size: var(--text-sm);
  }
</style>
