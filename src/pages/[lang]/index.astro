---
import Base from '../../layouts/Base.astro';
import WorkCard from '../../components/WorkCard.astro';
import { getFeaturedWorks } from '../../lib/content';
import { t, locales, type Lang } from '../../i18n/ui';
import { getRelativeLocaleUrl } from 'astro:i18n';

export function getStaticPaths() {
  return locales.map((lang) => ({ params: { lang } }));
}

const lang = Astro.params.lang as Lang;
const works = await getFeaturedWorks(lang);
---

<Base>
  <div class="home-grid">
    <div class="intro-cell">
      <h1>{t(lang, 'home.intro.title')}</h1>
      <p>{t(lang, 'home.intro.body')}</p>
    </div>
    {works.map((work) => <WorkCard work={work} lang={lang} />)}
  </div>
  <p class="view-all">
    <a href={getRelativeLocaleUrl(lang, 'works')}>{t(lang, 'home.viewAll')} →</a>
  </p>
</Base>

<style>
  .home-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--grid-gap);
  }
  @media (max-width: 64rem) {
    .home-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media (max-width: 40rem) {
    .home-grid {
      grid-template-columns: 1fr;
    }
  }
  /* 介绍块作为网格中的一格,与作品图块平起平坐(规格·首页) */
  .intro-cell h1 {
    margin: 0 0 var(--space-2);
    font-size: var(--text-xl);
    font-weight: 600;
    line-height: 1.3;
  }
  .intro-cell p {
    margin: 0;
    color: var(--color-muted);
    max-width: var(--width-prose);
  }
  .view-all {
    margin-top: var(--space-5);
  }
</style>
