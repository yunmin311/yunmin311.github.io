---
import { getCollection, render } from 'astro:content';
import { getRelativeLocaleUrl } from 'astro:i18n';
import Base from '../../../layouts/Base.astro';
import { hasTranslation, slugOf } from '../../../lib/content';
import { type Lang } from '../../../i18n/ui';
import { formatDate } from '../../../lib/format';

export async function getStaticPaths() {
  const entries = await getCollection('posts', ({ data }) => !data.draft);
  return entries.map((entry) => {
    const [lang, ...rest] = entry.id.split('/');
    return { params: { lang, slug: rest.join('/') }, props: { entry } };
  });
}

const { entry } = Astro.props;
const lang = Astro.params.lang as Lang;
const otherLang: Lang = lang === 'zh' ? 'en' : 'zh';
const slug = slugOf(entry.id);
const { Content } = await render(entry);

const altPath = (await hasTranslation('posts', otherLang, slug))
  ? getRelativeLocaleUrl(otherLang, `blog/${slug}`)
  : null;
---

<Base title={entry.data.title} description={entry.data.summary} altPath={altPath}>
  <article class="post">
    <h1>{entry.data.title}</h1>
    <time datetime={entry.data.date.toISOString().slice(0, 10)}>{formatDate(lang, entry.data.date)}</time>
    <div class="post-body">
      <Content />
    </div>
  </article>
</Base>

<style>
  .post {
    max-width: var(--width-prose);
  }
  .post h1 {
    margin: 0 0 var(--space-2);
    font-size: var(--text-xl);
    font-weight: 600;
  }
  .post time {
    color: var(--color-muted);
    font-size: var(--text-sm);
  }
  .post-body {
    margin-top: var(--space-4);
  }
  .post-body :global(img) {
    width: 100%;
    height: auto; /* 压掉 img 的 height 属性,否则照片会被拉变形(同封面的教训) */
    margin-block: var(--space-4);
  }
</style>
