---
import '../styles/tokens.css';
import { t, defaultLang, type Lang } from '../i18n/ui';
import { getRelativeLocaleUrl } from 'astro:i18n';

interface Props {
  title?: string;
  description?: string;
  /** 另一语言对应页的路径;不传则按语言前缀互换(适用于两边都存在的页面) */
  altPath?: string;
}

const lang = (Astro.currentLocale ?? defaultLang) as Lang;
const otherLang: Lang = lang === 'zh' ? 'en' : 'zh';
const siteName = t(lang, 'site.name');
const { title, description = t(lang, 'site.description'), altPath } = Astro.props;
const pageTitle = title ? `${title} — ${siteName}` : siteName;

const currentPath = Astro.url.pathname;
const switchPath =
  altPath ?? currentPath.replace(new RegExp(`^/${lang}(?=/|$)`), `/${otherLang}`);

const nav = [
  { href: getRelativeLocaleUrl(lang, 'works'), label: t(lang, 'nav.works') },
  { href: getRelativeLocaleUrl(lang, 'blog'), label: t(lang, 'nav.blog') },
  { href: getRelativeLocaleUrl(lang, 'about'), label: t(lang, 'nav.about') },
];
const year = new Date().getFullYear();
---

<html lang={lang === 'zh' ? 'zh-CN' : 'en'}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
  </head>
  <body>
    <header class="site-header">
      <a class="site-name" href={getRelativeLocaleUrl(lang)}>{siteName}</a>
      <nav class="site-nav">
        {nav.map((item) => <a href={item.href}>{item.label}</a>)}
        <span class="lang-switch">
          <a href={lang === 'en' ? currentPath : switchPath} aria-current={lang === 'en' ? 'page' : undefined}>EN</a>
          <span class="lang-sep">/</span>
          <a href={lang === 'zh' ? currentPath : switchPath} aria-current={lang === 'zh' ? 'page' : undefined}>中</a>
        </span>
      </nav>
    </header>
    <main class="site-main">
      <slot />
    </main>
    <footer class="site-footer">© {year} {siteName}</footer>
  </body>
</html>

<style is:global>
  * {
    box-sizing: border-box;
  }
  body {
    margin: 0;
    background: var(--color-bg);
    color: var(--color-text);
    font-family: var(--font-sans);
    font-size: var(--text-base);
    line-height: 1.6;
  }
  a {
    color: inherit;
    text-decoration: none;
  }
  a:hover {
    color: var(--color-accent);
    text-decoration: underline;
  }
  img {
    max-width: 100%;
    display: block;
  }
</style>

<style>
  .site-header,
  .site-main,
  .site-footer {
    max-width: var(--width-site);
    margin-inline: auto;
    padding-inline: var(--pad-page);
  }
  .site-header {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    justify-content: space-between;
    gap: var(--space-2) var(--space-4);
    padding-block: var(--space-4);
  }
  .site-name {
    font-size: var(--text-lg);
  }
  .site-nav {
    display: flex;
    align-items: baseline;
    gap: var(--space-3);
    font-size: var(--text-sm);
  }
  .lang-switch {
    margin-inline-start: var(--space-3);
    color: var(--color-muted);
  }
  .lang-switch a {
    color: var(--color-muted);
  }
  /* 当前语言不用下划线:下划线会让"中"看起来像"虫" */
  .lang-switch a[aria-current='page'] {
    color: var(--color-text);
    font-weight: 600;
  }
  .lang-switch a:hover {
    text-decoration: none;
    color: var(--color-text);
  }
  .lang-sep {
    margin-inline: var(--space-1);
  }
  .site-main {
    min-height: 60vh;
    padding-block: var(--space-5);
  }
  .site-footer {
    padding-block: var(--space-5);
    color: var(--color-muted);
    font-size: var(--text-sm);
  }
</style>
